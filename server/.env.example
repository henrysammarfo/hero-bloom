# CIRCUIT Backend — copy to .env and fill. Never commit .env.

# -----------------------------------------------------------------------------
# WDK (required for agent wallets and signing draw/repay)
# -----------------------------------------------------------------------------
# Prefer encrypted seed entropy (recommended). Generate:
#   npm run generate-seed
#   npm run encrypt-seed
# Then set:
WDK_SEED_ENTROPY_ENCRYPTED_B64=
WDK_SEED_PASSPHRASE=
#
# Fallback (dev-only): raw 12/24-word phrase. Avoid in production.
WDK_SEED_PHRASE=

# NOTE (Windows/Node 24): if you hit issues with entropy encryption, use:
WDK_SEED_PHRASE_ENCRYPTED_B64=

# -----------------------------------------------------------------------------
# Sepolia RPC (required)
# -----------------------------------------------------------------------------
# Full URL, e.g. https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_SEPOLIA_URL=

# -----------------------------------------------------------------------------
# Contract addresses (same as frontend — fill after npm run deploy:sepolia)
# -----------------------------------------------------------------------------
CIRCUIT_REGISTRY_ADDRESS=
CIRCUIT_POOL_ADDRESS=
MOCK_USDT_ADDRESS=

# -----------------------------------------------------------------------------
# Credit scoring — GET /agent/:id/score (use one of)
# -----------------------------------------------------------------------------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Flock AI (OpenAI-compatible): https://platform.flock.io — set base URL in code
FLOCK_API_KEY=
# Model: OpenAI default gpt-4o-mini; Flock e.g. qwen3-30b-a3b-instruct-2507
# SCORING_MODEL=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# -----------------------------------------------------------------------------
# API safety controls (recommended for any public demo)
# -----------------------------------------------------------------------------
# If set, POST endpoints require: header "x-api-key: <value>"
# CIRCUIT_API_KEY=
#
# Global kill-switch for anything that signs/sends transactions.
# CIRCUIT_WRITE_ENABLED=true
#
# Per-agent cooldown (ms) for draw/repay endpoints (prevents spam)
# CIRCUIT_AGENT_COOLDOWN_MS=60000
#
# Where audit JSONL is written (relative to server/ by default)
# CIRCUIT_AUDIT_LOG_PATH=circuit-audit.jsonl
#
# Persisted wallet-address -> derivation-index map (recommended)
# CIRCUIT_WALLET_MAP_PATH=.circuit-wallet-map.json
# If map is stale/missing, backend can scan derivation indices for recovery
# CIRCUIT_WALLET_SCAN_LIMIT=200

# -----------------------------------------------------------------------------
# Optional: Supabase for persisting agent index mapping / credit scores
# -----------------------------------------------------------------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
