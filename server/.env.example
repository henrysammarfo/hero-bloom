# CIRCUIT Backend — Copy to .env and fill in your values. DO NOT commit .env

# WDK — 12-word BIP39 phrase (dev only). Use encrypted version for production.
WDK_SEED_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Sepolia RPC (from your Alchemy key)
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_key_here

# Contract addresses
CIRCUIT_REGISTRY_ADDRESS=0x...
CIRCUIT_POOL_ADDRESS=0x...
MOCK_USDT_ADDRESS=0x...

# Credit scoring — OpenAI (optional)
OPENAI_API_KEY=sk-proj-...

# Flock AI (OpenAI-compatible) — optional alternative to OpenAI
FLOCK_API_KEY=sk-...

PORT=3001
FRONTEND_URL=http://localhost:8080
NODE_ENV=development

# OpenClaw agent IDs (comma-separated)
CIRCUIT_MANAGED_AGENT_IDS=0x...
