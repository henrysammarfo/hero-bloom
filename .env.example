# CIRCUIT — Sepolia Testnet
# Copy this file to .env and fill in the values. Do not commit .env.

# -----------------------------------------------------------------------------
# Required for wallet connect + Sepolia RPC
# -----------------------------------------------------------------------------

# Alchemy: create app at https://dashboard.alchemy.com/ (Ethereum → Sepolia)
# RPC URL will be: https://eth-sepolia.g.alchemy.com/v2/<this_key>
VITE_ALCHEMY_API_KEY=

# Reown (WalletConnect): create project at https://dashboard.reown.com/
VITE_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# Optional (contract verification, history, etc.)
# -----------------------------------------------------------------------------

# Etherscan: https://etherscan.io/myapikey (for Sepolia: sepolia.etherscan.io)
# VITE_ETHERSCAN_API_KEY=

# Backend / deploy scripts only — NEVER use in frontend. Not a VITE_ variable.
# FUNDED_WALLET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Contract addresses (fill after: npm run deploy:sepolia)
# -----------------------------------------------------------------------------
# VITE_CIRCUIT_REGISTRY_ADDRESS=
# VITE_CIRCUIT_POOL_ADDRESS=
# VITE_MOCK_USDT_ADDRESS=

# -----------------------------------------------------------------------------
# Backend API (optional — for WDK draw/repay and credit scoring)
# -----------------------------------------------------------------------------
# Set to backend URL when server is running (e.g. http://localhost:3001)
# VITE_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Only VITE_* variables are exposed to the browser (Vite requirement).
# - Get Sepolia test ETH from https://www.alchemy.com/faucets/ethereum-sepolia
#   or https://sepoliafaucet.com — no env key, just fund your wallet.
# - Never commit .env or share private keys. Rotate keys if they were ever exposed.
