# CIRCUIT — Sepolia Testnet
# Copy this file to .env and fill in your values. DO NOT commit .env

# Frontend (VITE_* is exposed to browser — no secrets here)
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

VITE_MOCK_USDT_ADDRESS=0x...
VITE_CIRCUIT_REGISTRY_ADDRESS=0x...
VITE_CIRCUIT_POOL_ADDRESS=0x...

# Backend API URL (use http://localhost:3001 for local dev)
VITE_API_URL=http://localhost:3001

# NEVER put private keys or seeds here — backend only
FUNDED_WALLET_PRIVATE_KEY=your_funded_wallet_private_key_here
